&GLOBAL
  PROJECT bulk_au_rel
  RUN_TYPE ENERGY
  PRINT_LEVEL MEDIUM
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep

  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS

    &MGRID
      CUTOFF 600
      REL_CUTOFF 80
    &END MGRID

    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 1.0E-8
      MAX_SCF 500
      ADDED_MOS 120

      &SMEAR
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE [K] 300
      &END SMEAR

      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION

      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.10
        NBROYDEN 8
      &END MIXING
    &END SCF

    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC

    &KPOINTS
      SCHEME MONKHORST-PACK 10 10 10
      FULL_GRID .TRUE.
    &END KPOINTS

    &PRINT
      &DOS
        NDIGITS 12
        FILENAME bulk_au_dos
      &END DOS

      &BAND_STRUCTURE
        FILE_NAME bulk_au_band
        ADDED_MOS 40

        &KPOINT_SET
          UNITS B_VECTOR
          NPOINTS 40
          SPECIAL_POINT 0.0 0.0 0.0
          SPECIAL_POINT 0.0 0.5 0.5
        &END KPOINT_SET

        &KPOINT_SET
          UNITS B_VECTOR
          NPOINTS 40
          SPECIAL_POINT 0.0 0.5 0.5
          SPECIAL_POINT 0.25 0.5 0.75
        &END KPOINT_SET

        &KPOINT_SET
          UNITS B_VECTOR
          NPOINTS 40
          SPECIAL_POINT 0.25 0.5 0.75
          SPECIAL_POINT 0.5 0.5 0.5
        &END KPOINT_SET

        &KPOINT_SET
          UNITS B_VECTOR
          NPOINTS 40
          SPECIAL_POINT 0.5 0.5 0.5
          SPECIAL_POINT 0.0 0.0 0.0
        &END KPOINT_SET

      &END BAND_STRUCTURE
    &END PRINT

  &END DFT

  &SUBSYS
    &CELL
      ABC 4.07820000 4.07820000 4.07820000
      ALPHA_BETA_GAMMA 90 90 90
      PERIODIC XYZ
    &END CELL

    &COORD
      Au 0.00000000 0.00000000 0.00000000
      Au 0.00000000 2.03910000 2.03910000
      Au 2.03910000 0.00000000 2.03910000
      Au 2.03910000 2.03910000 0.00000000
    &END COORD

    &KIND Au
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q11
    &END KIND
  &END SUBSYS

&END FORCE_EVAL
