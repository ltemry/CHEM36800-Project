&GLOBAL
  PROJECT Au4_charge0
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME /home/sjzhao/spack/opt/spack/linux-cascadelake/cp2k-2026.1-ldkgppgxffmfljh6amioudbsetbzep4p/share/cp2k/data/BASIS_MOLOPT_UCL
    POTENTIAL_FILE_NAME /home/sjzhao/spack/opt/spack/linux-cascadelake/cp2k-2026.1-ldkgppgxffmfljh6amioudbsetbzep4p/share/cp2k/data/GTH_POTENTIALS
    CHARGE 0
    MULTIPLICITY 0
    UKS FALSE

    &MGRID
      CUTOFF 600
      REL_CUTOFF 80
      NGRIDS 5
    &END MGRID

    &QS
      METHOD GPW
      EPS_DEFAULT 1.0E-12
    &END QS

    &POISSON
      PERIODIC NONE
      PSOLVER MT
    &END POISSON

    &SCF
      EPS_SCF 1.0E-7
      MAX_SCF 200
      SCF_GUESS ATOMIC
      &OT
        PRECONDITIONER FULL_SINGLE_INVERSE
        MINIMIZER DIIS
      &END OT
      &OUTER_SCF
        MAX_SCF 20
        EPS_SCF 1.0E-7
      &END OUTER_SCF
    &END SCF

    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
          TYPE DFTD3(BJ)
          REFERENCE_FUNCTIONAL PBE
          PARAMETER_FILE_NAME dftd3.dat
        &END PAIR_POTENTIAL
      &END VDW_POTENTIAL
    &END XC
  &END DFT

  &SUBSYS
    &CELL
      ABC 30.0 30.0 30.0
      PERIODIC NONE
    &END CELL

    &TOPOLOGY
      COORD_FILE_FORMAT XYZ
      COORD_FILE_NAME Au4.xyz
    &END TOPOLOGY

    &KIND Au
      BASIS_SET TZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q11
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
